# Server
PORT=3000

# MySQL (cloud)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# Set to 1 for most managed MySQL providers
MYSQL_SSL=1

# JWT signing secret (use a long random string in production)
JWT_SECRET=

# Secret for registering new admin accounts
ADMIN_REGISTRATION_SECRET=admin123
